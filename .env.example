# ═══════════════════════════════════════════════════════════════
# Commune de Tarmigt — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Server
PORT=3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=commune_tarmigt
DB_SSL=false

# Authentication (REQUIRED for admin panel)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here

# OpenAI API Key (for chatbot — optional, chatbot won't work without it)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Cloudinary (for image uploads — optional)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# CORS Origins (comma-separated, leave empty to allow all)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
